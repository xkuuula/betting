TELEGRAM_BOT_TOKEN=1234567890:replace_with_your_telegram_bot_token
TELEGRAM_CHAT_ID=-1001234567890
MINIMUM_BET_SIZE_USD=5000
MAX_TRADE_PRICE=0.5

# Optional comma-separated filters.
ALLOWED_TOURNAMENTS=
EXCLUDED_TOURNAMENTS=

# The defaults are production endpoints documented or used by Polymarket clients.
RTDS_WS_URL=wss://ws-live-data.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# Discovery refresh for active CS2 markets and CLOB token subscriptions.
DISCOVERY_INTERVAL_SECONDS=60

# Leave true for the lowest-latency dual-source setup.
ENABLE_CLOB_MARKET_WS=true

# Telegram HTML parse mode is used for rich links.
LOG_LEVEL=INFO
